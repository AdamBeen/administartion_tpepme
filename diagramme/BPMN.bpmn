      <bpmndi:BPMNShape id="Shape_Task_Vector_RAG" bpmnElement="Task_Vector_RAG" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="1650" y="250" width="190" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_GraphRAG" bpmnElement="Task_GraphRAG" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="1650" y="440" width="190" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_Retrieval_Join" bpmnElement="Gateway_Retrieval_Join" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022"><dc:Bounds x="1920" y="335" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Analyze_Dossier" bpmnElement="Task_Analyze_Dossier" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="2050" y="320" width="200" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Evaluate_Dossier" bpmnElement="Task_Evaluate_Dossier" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="2310" y="320" width="210" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_HITL_Router" bpmnElement="Task_HITL_Router" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="2580" y="320" width="170" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Clean_Response" bpmnElement="Task_Clean_Response" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="2810" y="320" width="210" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Debug_Timeline" bpmnElement="Task_Debug_Timeline" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="3080" y="320" width="190" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Skillspector_Report" bpmnElement="Task_Skillspector_Report" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="3330" y="220" width="210" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Save_Security_Report" bpmnElement="Task_Save_Security_Report" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="3600" y="220" width="190" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Display_Result" bpmnElement="Task_Display_Result" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="3850" y="220" width="210" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Download_Report" bpmnElement="Task_Download_Report" bioc:stroke="#6b3c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3c00"><dc:Bounds x="4120" y="220" width="200" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Completed" bpmnElement="End_Completed" bioc:stroke="#831311" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#831311"><dc:Bounds x="4400" y="242" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Mode_di" bpmnElement="Flow_Start_Mode"><di:waypoint x="136" y="360" /><di:waypoint x="180" y="360" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Mode_Upload_di" bpmnElement="Flow_Mode_Upload"><di:waypoint x="330" y="360" /><di:waypoint x="390" y="360" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Upload_Gateway_di" bpmnElement="Flow_Upload_Gateway"><di:waypoint x="580" y="360" /><di:waypoint x="650" y="360" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Secured_Static_di" bpmnElement="Flow_Secured_Static"><di:waypoint x="675" y="335" /><di:waypoint x="675" y="160" /><di:waypoint x="770" y="160" /><bpmndi:BPMNLabel><dc:Bounds x="695" y="180" width="60" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Unsecured_To_Workflow_di" bpmnElement="Flow_Unsecured_To_Workflow"><di:waypoint x="700" y="360" /><di:waypoint x="770" y="360" /><bpmndi:BPMNLabel><dc:Bounds x="710" y="338" width="82" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Static_Groq_di" bpmnElement="Flow_Static_Groq"><di:waypoint x="960" y="160" /><di:waypoint x="1020" y="160" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Groq_Blocked_di" bpmnElement="Flow_Groq_Blocked"><di:waypoint x="1210" y="160" /><di:waypoint x="1280" y="160" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Blocked_di" bpmnElement="Flow_Blocked"><di:waypoint x="1305" y="135" /><di:waypoint x="1305" y="100" /><di:waypoint x="1410" y="100" /><bpmndi:BPMNLabel><dc:Bounds x="1330" y="82" width="45" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Allowed_To_Workflow_di" bpmnElement="Flow_Allowed_To_Workflow"><di:waypoint x="1305" y="185" /><di:waypoint x="1305" y="210" /><di:waypoint x="860" y="210" /><di:waypoint x="860" y="320" /><bpmndi:BPMNLabel><dc:Bounds x="1085" y="190" width="55" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Block_Report_di" bpmnElement="Flow_Block_Report"><di:waypoint x="1600" y="100" /><di:waypoint x="3435" y="100" /><di:waypoint x="3435" y="220" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Extract_Summary_di" bpmnElement="Flow_Extract_Summary"><di:waypoint x="950" y="360" /><di:waypoint x="1010" y="360" /></bpmndi:BPMNEdge>
