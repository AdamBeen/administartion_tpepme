# === Astra DB (Cassandra compatible) ===
ASTRA_DB_APPLICATION_TOKEN=your_astra_db_application_token_here
ASTRA_DB_API_ENDPOINT=https://your-db-id-region.apps.astra.datastax.com
ASTRA_DB_KEYSPACE=admintpe_v1

# === Groq API (Llama — tâches courtes) ===
GROQ_API_KEY=your_groq_api_key_here
LLM_SHORT_MODEL=llama-3.3-70b-versatile

# === Google Gemini API (tâches longues) ===
GOOGLE_API_KEY=your_google_api_key_here
LLM_LONG_MODEL=gemini-1.5-flash

# === Backend ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# === Frontend ===
FRONTEND_PORT=3000

# === Workflow ===
WORKFLOW_VERSION=baseline_security_mode
MAX_FILE_SIZE_MB=20
